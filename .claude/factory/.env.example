# Factory environment variables
# Copy to .env and source before running: source .env

# Pi Ollama endpoint (change if your Pi IP differs)
export OLLAMA_HOST="http://192.168.1.44:11434"

# Anthropic API key — used ONLY for Haiku reviews
# Get from: https://console.anthropic.com/
export ANTHROPIC_API_KEY="sk-ant-..."

# Optional: override default model per-session
# export DEFAULT_MODEL="stable-code:3b"
